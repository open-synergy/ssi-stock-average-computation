<odoo>
  <data>
    <!-- E.2: res.groups for transaction object -->
    <record id="stock_average_computation_viewer_group" model="res.groups">
      <field name="name">Viewer</field>
      <field name="category_id" ref="stock_average_computation_workflow" />
    </record>
    <record id="stock_average_computation_user_group" model="res.groups">
      <field name="name">User</field>
      <field name="category_id" ref="stock_average_computation_workflow" />
      <field
                name="implied_ids"
                eval="[(4, ref('stock_average_computation_viewer_group'))]"
            />
    </record>
    <record id="stock_average_computation_validator_group" model="res.groups">
      <field name="name">Validator</field>
      <field name="category_id" ref="stock_average_computation_workflow" />
      <field
                name="implied_ids"
                eval="[(4, ref('stock_average_computation_user_group'))]"
            />
    <field
                name="users"
                eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"
            />
    </record>
    <record id="stock_average_computation_company_group" model="res.groups">
      <field name="name">Company</field>
      <field name="category_id" ref="stock_average_computation_data_ownership" />
    </record>
    <record id="stock_average_computation_child_company_group" model="res.groups">
      <field name="name">Company and All Child Companies</field>
      <field name="category_id" ref="stock_average_computation_data_ownership" />
      <field
                name="implied_ids"
                eval="[(4, ref('stock_average_computation_company_group'))]"
            />
    </record>
    <record id="stock_average_computation_all" model="res.groups">
      <field name="name">All</field>
      <field name="category_id" ref="stock_average_computation_data_ownership" />
      <field
                name="implied_ids"
                eval="[(4, ref('stock_average_computation_company_group'))]"
            />
        <field
                name="users"
                eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"
            />
    </record>
  </data>
</odoo>
