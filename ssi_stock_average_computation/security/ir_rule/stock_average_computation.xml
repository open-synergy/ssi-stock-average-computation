<odoo>
  <data>
    <!-- E.4: ir.rule for transaction object -->
    <record id="stock_average_computation_internal_user_rule" model="ir.rule">
      <field name="name">stock_average_computation - Internal User</field>
      <field name="model_id" ref="model_stock_average_computation" />
      <field name="groups" eval="[(6,0,[ref('base.group_user')])]" />
      <field name="perm_read" eval="1" />
      <field name="perm_write" eval="1" />
      <field name="perm_create" eval="1" />
      <field name="perm_unlink" eval="1" />
      <field name="domain_force">[("user_id","=",user.id)]</field>
    </record>
    <record id="stock_average_computation_company_rule" model="ir.rule">
      <field name="name">stock_average_computation - Responsible to company data</field>
      <field name="model_id" ref="model_stock_average_computation" />
      <field
                name="groups"
                eval="[(6,0,[ref('stock_average_computation_company_group')])]"
            />
      <field name="perm_read" eval="1" />
      <field name="perm_write" eval="1" />
      <field name="perm_create" eval="1" />
      <field name="perm_unlink" eval="1" />
      <field name="domain_force">[("company_id","=",user.company_id.id)]</field>
    </record>
    <record id="stock_average_computation_child_company_rule" model="ir.rule">
      <field
                name="name"
            >stock_average_computation - Responsible to company and all child companies data</field>
      <field name="model_id" ref="model_stock_average_computation" />
      <field
                name="groups"
                eval="[(6,0,[ref('stock_average_computation_child_company_group')])]"
            />
      <field name="perm_read" eval="1" />
      <field name="perm_write" eval="1" />
      <field name="perm_create" eval="1" />
      <field name="perm_unlink" eval="1" />
      <field name="domain_force">[("company_id","in",user.company_ids.ids)]</field>
    </record>
    <record id="stock_average_computation_all_rule" model="ir.rule">
      <field name="name">stock_average_computation - Responsible to all data</field>
      <field name="model_id" ref="model_stock_average_computation" />
      <field name="groups" eval="[(6,0,[ref('stock_average_computation_all')])]" />
      <field name="perm_read" eval="1" />
      <field name="perm_write" eval="1" />
      <field name="perm_create" eval="1" />
      <field name="perm_unlink" eval="1" />
      <field name="domain_force">[(1,'=',1)]</field>
    </record>
  </data>
</odoo>
