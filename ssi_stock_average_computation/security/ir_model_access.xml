<odoo>
    <data noupdate="0">
        <!-- D.5.1: read-only access for all users -->
        <record id="stock_average_computation_type_access_all" model="ir.model.access">
            <field name="name">Stock Average Computation Type - all</field>
            <field name="model_id" ref="model_stock_average_computation_type" />
            <field name="group_id" eval="False" />
            <field name="perm_read" eval="1" />
            <field name="perm_write" eval="0" />
            <field name="perm_create" eval="0" />
            <field name="perm_unlink" eval="0" />
        </record>
        <!-- D.5.2: full access for configurator group -->
        <record
            id="stock_average_computation_type_access_configurator"
            model="ir.model.access"
        >
            <field name="name">Stock Average Computation Type - configurator</field>
            <field name="model_id" ref="model_stock_average_computation_type" />
            <field name="group_id" ref="stock_average_computation_type_configurator" />
            <field name="perm_read" eval="1" />
            <field name="perm_write" eval="1" />
            <field name="perm_create" eval="1" />
            <field name="perm_unlink" eval="1" />
        </record>
    </data>
</odoo>
