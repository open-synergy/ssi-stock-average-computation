<odoo>
    <data>
        <!-- D.1 View: Search -->
        <record id="stock_average_computation_type_view_search" model="ir.ui.view">
            <field name="name">stock_average_computation_type - search</field>
            <field name="model">stock_average_computation_type</field>
            <field
                name="inherit_id"
                ref="ssi_master_data_mixin.mixin_master_data_view_search"
            />
            <field name="mode">primary</field>
            <field name="arch" type="xml">
                <data>
                </data>
            </field>
        </record>

        <!-- D.1 View: Tree -->
        <record id="stock_average_computation_type_view_tree" model="ir.ui.view">
            <field name="name">stock_average_computation_type - tree</field>
            <field name="model">stock_average_computation_type</field>
            <field
                name="inherit_id"
                ref="ssi_master_data_mixin.mixin_master_data_view_tree"
            />
            <field name="mode">primary</field>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//field[@name='name']" position="after">
                    </xpath>
                </data>
            </field>
        </record>

        <!-- D.1 View: Form -->
        <record id="stock_average_computation_type_view_form" model="ir.ui.view">
            <field name="name">stock_average_computation_type - form</field>
            <field name="model">stock_average_computation_type</field>
            <field name="mode">primary</field>
            <field
                name="inherit_id"
                ref="ssi_master_data_mixin.mixin_master_data_view_form"
            />
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//page[last()]" position="before">
                        <page name="product" string="Product">
                        </page>
                        <page name="inventory" string="Inventory">
                        </page>
                    </xpath>
                </data>
            </field>
        </record>

        <!-- D.1 Window Action -->
        <record
            id="stock_average_computation_type_action"
            model="ir.actions.act_window"
        >
            <field name="name">Stock Average Computation Types</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">stock_average_computation_type</field>
            <field name="view_mode">tree,form</field>
        </record>

        <!-- D.1 Menu (placeholder parent and groups) -->
        <menuitem
            id="stock_average_computation_type_menu"
            name="Types"
            action="stock_average_computation_type_action"
            groups="stock_average_computation_type_configurator"
            parent="menu_average_computation_config"
        />

    </data>
</odoo>
