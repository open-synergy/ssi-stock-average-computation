<odoo>
  <data>
    <!-- E.6: sequence.template for transaction object -->
    <record id="sequence_template_stock_average_computation" model="sequence.template">
      <field name="name">Standard</field>
      <field name="model_id" ref="model_stock_average_computation" />
      <field name="sequence" eval="100" />
      <field name="initial_string">/</field>
  <field
                name="sequence_field_id"
                search="[('model_id.model','=','stock_average_computation'),('name','=','name')]"
            />
  <field
                name="date_field_id"
                search="[('model_id.model','=','stock_average_computation'),('name','=','date')]"
            />
      <field name="computation_method">use_python</field>
      <field name="python_code">result=True</field>
      <field name="sequence_id" ref="sequence_stock_average_computation" />
      <field name="sequence_selection_method">use_sequence</field>
      <field name="add_custom_prefix" eval="0" />
      <field name="add_custom_suffix" eval="0" />
    </record>
  </data>
</odoo>
